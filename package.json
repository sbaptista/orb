{
  "name": "orb",
  "version": "0.6.66",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-repository-bundle.mjs",
    "dev": "rm -rf .next && next dev --experimental-https --experimental-https-cert localhost+1.pem --experimental-https-key localhost+1-key.pem -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && node scripts/verify-ui-catalog.js",
    "generate-contract": "ts-node scripts/generate-orb-contract.ts",
    "eval": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx tsx scripts/orb-eval.ts",
    "eval:t1": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx tsx scripts/orb-eval.ts --tier 1",
    "eval:t2": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx tsx scripts/orb-eval.ts --tier 2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.9",
    "@anthropic-ai/sdk": "^0.92.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "ai": "^4.1.24",
    "driver.js": "^1.4.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "yaml": "^2.9.0"
  }
}
